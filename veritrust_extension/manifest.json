{
  "manifest_version": 3,
  "name": "VeriTrust AI",
  "version": "1.0",
  "description": "Automatically detects AI-generated or edited images on webpages.",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["<all_urls>", "http://localhost:8000/*"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["style.css"]
    }
  ]
}